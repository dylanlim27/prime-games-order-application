## Ignore Visual Studio build artifacts and cache files
# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bin/
obj/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/

# Mono Auto Generated Files
mono_crash.*

# Windows image cache files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin outputs
$RECYCLE.BIN/
